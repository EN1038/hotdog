generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  WAITING_FOR_STORE_ACCEPTANCE
  PREPARING
  READY_FOR_PICKUP
  READY_FOR_DELIVERY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

/// Where the order was taken (staff picks; customer online is forced to ORDER_CUSTOMER)
enum SalesChannel {
  STOREFRONT
  FACEBOOK
  APP_DELIVERY
  OTHER
  ORDER_CUSTOMER
}

enum StaffRole {
  SELLER
  DELIVERY
}

enum BrandMemberRole {
  OWNER
  MANAGER
}

enum PriceRange {
  UNDER_100
  FROM_101_250
  FROM_251_500
  FROM_501_1000
  OVER_1000
}

enum MenuPromoType {
  AMOUNT
  PERCENT
}

enum OptionGroupMode {
  MANUAL
  FROM_MENU
}

model Admin {
  id              String             @id @default(cuid())
  username        String             @unique
  passwordHash    String
  /// AES-GCM encrypted plaintext for platform recovery/view only (never sent to brand admins)
  passwordEnc     String?
  isPlatformAdmin Boolean            @default(false)
  /// LINE user id after admin adds the Official Account and links by one-time code
  lineUserId      String?            @unique
  lineNotifyEnabled Boolean          @default(true)
  /// Receive per-branch operating-day summary at cutoff
  lineNotifyDailySummary Boolean     @default(true)
  /// One-time LINE link code (shown only while logged into admin)
  lineLinkCode           String?
  lineLinkCodeExpiresAt  DateTime?
  createdAt       DateTime           @default(now())
  brandMembers    BrandMember[]
  activityLogs    AdminActivityLog[]

  @@index([lineLinkCode])
}

model Brand {
  id              String             @id @default(cuid())
  code            String             @unique
  name            String
  nameTh          String?
  nameEn          String?
  siteTitle       String?
  siteDescription String?
  logoUrl         String?
  /** รูปปกหัวหน้าเข้าสู่ระบบเมื่อเข้าจากลิงก์แบรนด์ (ยังไม่ระบุสาขา) */
  coverImageUrl   String?
  /** เบอร์ติดต่อแบรนด์ (ลูกค้ากด “แจ้งให้เราทราบ” ฯลฯ) */
  contactPhone    String?
  color           String             @default("#dc2626")
  /// How many queue tickets to print when opening a queue (1–5). 2 = shop + customer.
  queueTicketCopies Int              @default(1)
  createdAt       DateTime           @default(now())
  branches        Branch[]
  members         BrandMember[]
  activityLogs    AdminActivityLog[]
}

/** Audit trail for platform + brand admin mutations */
model AdminActivityLog {
  id            String   @id @default(cuid())
  createdAt     DateTime @default(now())
  adminId       String?
  adminUsername String
  action        String
  summary       String
  brandId       String?
  brandName     String?
  branchId      String?
  branchName    String?
  entityType    String?
  entityId      String?
  entityName    String?
  metadata      Json?
  admin         Admin?   @relation(fields: [adminId], references: [id], onDelete: SetNull)
  brand         Brand?   @relation(fields: [brandId], references: [id], onDelete: SetNull)
  branch        Branch?  @relation(fields: [branchId], references: [id], onDelete: SetNull)

  @@index([createdAt])
  @@index([brandId, createdAt])
  @@index([branchId, createdAt])
  @@index([action, createdAt])
  @@index([adminId, createdAt])
}

model BrandMember {
  id        String          @id @default(cuid())
  adminId   String
  brandId   String
  role      BrandMemberRole @default(OWNER)
  createdAt DateTime        @default(now())
  admin     Admin           @relation(fields: [adminId], references: [id], onDelete: Cascade)
  brand     Brand           @relation(fields: [brandId], references: [id], onDelete: Cascade)

  @@unique([adminId, brandId])
}

/// Idempotency log: one LINE daily summary push per branch operating day
model LineDailySummaryLog {
  id             String   @id @default(cuid())
  branchId       String
  operatingDay   DateTime @db.Date
  sentAt         DateTime @default(now())
  recipientCount Int      @default(0)
  branch         Branch   @relation(fields: [branchId], references: [id], onDelete: Cascade)

  @@unique([branchId, operatingDay])
  @@index([sentAt])
}

  /** Platform-level settings (marketplace shell). Brand identity lives on Brand. */
  model SiteSettings {
  id              String   @id @default("default")
  siteName        String   @default("SkillSale")
  siteTitle       String   @default("SkillSale - ระบบสั่งอาหารออนไลน์")
  siteDescription String?
  /** Mark / letter-style icon (square). */
  iconUrl         String?
  /** Full wordmark logo. */
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#0B2A4A")
  /** Which asset to show: "icon" | "logo" */
  markSidebar     String   @default("icon")
  markLogin       String   @default("logo")
  markHome        String   @default("logo")
  markOrder       String   @default("icon")
  markFavicon     String   @default("icon")
  /// LINE Messaging API channel access token (optional; env can override)
  lineChannelAccessToken String?
  /// LINE Messaging API channel secret (optional; env can override)
  lineChannelSecret      String?
  /// Master switch for outbound LINE notifications
  lineMessagingEnabled   Boolean  @default(false)
  /// Notify linked branch staff when a new order arrives
  lineNotifyStaffOnNewOrder Boolean @default(true)
  /// Notify linked brand owners/managers with daily cutoff summary
  lineNotifyBrandDailySummary Boolean @default(true)
  updatedAt       DateTime @updatedAt
}

/** Store type tags for branch primary/secondary category (e.g. อาหารไทย). */
model RestaurantType {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  sortOrder Int      @default(0)
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

/** Platform-managed staff new-order alert sounds. */
model AlertSound {
  id        String   @id @default(cuid())
  name      String
  fileUrl   String
  isActive  Boolean  @default(true)
  sortOrder Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  branches  Branch[]
}

model Branch {
  id                 String             @id @default(cuid())
  brandId            String?
  code               String?
  name               String
  nameTh             String?
  nameEn             String?
  imageUrl           String?
  address            String?
  latitude           Float?
  longitude          Float?
  phone              String?
  primaryCategory    String?
  secondaryCategories String[]           @default([])
  priceRange         PriceRange?
  ownerMessage       String?
  extraMessage       String?
  isOpen             Boolean            @default(true)
  /// Hidden from customer storefront; still visible in admin
  isHidden           Boolean            @default(false)
  /** @deprecated Prefer storefrontHours / deliveryHours */
  opensAt            String?
  /** @deprecated Prefer storefrontHours / deliveryHours */
  closesAt           String?
  storefrontHours    Json?
  deliveryHours      Json?
  allowAdvanceOrder  Boolean            @default(true)
  autoAcceptOrders   Boolean            @default(false)
  /// Staff new-order alert sound (from platform library)
  alertSoundId       String?
  createdAt          DateTime           @default(now())
  brand              Brand?               @relation(fields: [brandId], references: [id])
  alertSound         AlertSound?          @relation(fields: [alertSoundId], references: [id], onDelete: SetNull)
  staff              Staff[]
  menuItems          BranchMenuItem[]
  menuCategories     MenuCategory[]
  optionGroups       BranchOptionGroup[]
  deliveryLocations  DeliveryLocation[]
  orders             Order[]
  shifts             BranchShift[]
  shareCodes         BranchShareCode[]
  lineDailySummaries LineDailySummaryLog[]
  activityLogs       AdminActivityLog[]

  @@unique([brandId, code])
  @@index([alertSoundId])
}

/// Staff open/close round for a branch (multiple per calendar day).
model BranchShift {
  id              String    @id @default(cuid())
  branchId        String
  /// Bangkok calendar date of this round
  calendarDate    DateTime  @db.Date
  roundNumber     Int
  openedAt        DateTime  @default(now())
  closedAt        DateTime?
  openedByStaffId String?
  closedByStaffId String?
  /// Float / change money at open (ตังทอน)
  openingCash     Decimal   @db.Decimal(10, 2)
  /// Optional note when opening the round (e.g. เงินทอนสำหรับเปิดร้าน)
  note            String?
  branch          Branch    @relation(fields: [branchId], references: [id], onDelete: Cascade)
  openedByStaff   Staff?    @relation("ShiftOpenedByStaff", fields: [openedByStaffId], references: [id], onDelete: SetNull)
  closedByStaff   Staff?    @relation("ShiftClosedByStaff", fields: [closedByStaffId], references: [id], onDelete: SetNull)
  orders          Order[]

  @@unique([branchId, calendarDate, roundNumber])
  @@index([branchId, closedAt])
  @@index([branchId, calendarDate])
}

model Staff {
  id                String                @id @default(cuid())
  branchId          String
  phone             String                @unique
  name              String?
  gender            String?
  age               Int?
  imageUrl          String?
  isActive          Boolean               @default(true)
  /// LINE user id after staff adds the Official Account and links by phone
  lineUserId        String?               @unique
  lineNotifyEnabled Boolean               @default(true)
  createdAt         DateTime              @default(now())
  branch            Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roles             StaffRoleAssignment[]
  createdOrders     Order[]               @relation("OrderCreatedByStaff")
  openedShifts      BranchShift[]         @relation("ShiftOpenedByStaff")
  closedShifts      BranchShift[]         @relation("ShiftClosedByStaff")
}

model StaffRoleAssignment {
  id      String    @id @default(cuid())
  staffId String
  role    StaffRole
  staff   Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, role])
}

model BranchMenuItem {
  id               String                       @id @default(cuid())
  branchId         String
  name             String
  /// Delivery channel price (base)
  price            Decimal                      @db.Decimal(10, 2)
  /// Pickup channel price; null = same as delivery price
  pickupPrice      Decimal?                     @db.Decimal(10, 2)
  /// Storefront/reference price only (not ordered online); null = same as delivery
  storefrontPrice  Decimal?                     @db.Decimal(10, 2)
  sellDelivery     Boolean                      @default(true)
  sellPickup       Boolean                      @default(true)
  sellStorefront   Boolean                      @default(true)
  promoEnabled     Boolean                      @default(false)
  promoType        MenuPromoType?
  promoValue       Decimal?                     @db.Decimal(10, 2)
  promoContinuous  Boolean                      @default(false)
  promoStartsAt    DateTime?
  promoEndsAt      DateTime?
  description      String?
  categoryId       String?
  imageUrl         String?
  isHidden         Boolean                      @default(false)
  /// Hidden from staff keyed-order menu (still visible to customers unless isHidden)
  hideFromStaff    Boolean                      @default(false)
  isOutOfStock     Boolean                      @default(false)
  sortOrder        Int                          @default(0)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  branch           Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category         MenuCategory?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  optionGroupLinks BranchMenuItemOptionGroup[]
  optionGroupMenuSources BranchOptionGroupMenuItem[]
  orderItems       OrderItem[]
}

model MenuCategory {
  id         String            @id @default(cuid())
  branchId   String
  name       String
  sortOrder  Int               @default(0)
  createdAt  DateTime          @default(now())
  branch     Branch            @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menuItems  BranchMenuItem[]

  @@unique([branchId, name])
}

/** Copy pack code — paste into another branch to import menu/categories/options */
model BranchShareCode {
  id             String   @id @default(cuid())
  code           String   @unique
  sourceBranchId String
  createdAt      DateTime @default(now())
  sourceBranch   Branch   @relation(fields: [sourceBranchId], references: [id], onDelete: Cascade)
}

/** Shared option heading library per branch */
model BranchOptionGroup {
  id                       String                       @id @default(cuid())
  branchId                 String
  name                     String
  mode                     OptionGroupMode              @default(MANUAL)
  required                 Boolean                      @default(false)
  /// Minimum selections (counting duplicates when allowDuplicateSelections)
  minSelect                Int                          @default(0)
  maxSelect                Int                          @default(1)
  allowDuplicateSelections Boolean                      @default(false)
  sortOrder                Int                          @default(0)
  createdAt                DateTime                     @default(now())
  branch                   Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  options                  BranchOption[]
  menuItemSources          BranchOptionGroupMenuItem[]
  menuItemLinks            BranchMenuItemOptionGroup[]
}

/// Menu items offered as selectable options (FROM_MENU mode)
model BranchOptionGroupMenuItem {
  id         String            @id @default(cuid())
  groupId    String
  menuItemId String
  sortOrder  Int               @default(0)
  isEnabled  Boolean           @default(true)
  priceDelta Decimal           @default(0) @db.Decimal(10, 2)
  createdAt  DateTime          @default(now())
  group      BranchOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
  menuItem   BranchMenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)

  @@unique([groupId, menuItemId])
  @@index([groupId])
}

model BranchOption {
  id         String            @id @default(cuid())
  groupId    String
  name       String
  priceDelta Decimal           @default(0) @db.Decimal(10, 2)
  createdAt  DateTime          @default(now())
  group      BranchOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model BranchMenuItemOptionGroup {
  id         String            @id @default(cuid())
  menuItemId String
  groupId    String
  createdAt  DateTime          @default(now())
  menuItem   BranchMenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  group      BranchOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, groupId])
}

model DeliveryLocation {
  id               String  @id @default(cuid())
  branchId         String
  name             String
  deliveryFee      Decimal @default(0) @db.Decimal(10, 2)
  /// When true, customer must enter a full delivery address at checkout
  isCustomAddress  Boolean @default(false)
  address          String?
  latitude         Float?
  longitude        Float?
  branch           Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders           Order[]
}

model Customer {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  createdAt DateTime @default(now())
  orders    Order[]
}

/// Pending Taximail OTP challenge for customer phone login
model CustomerOtpChallenge {
  id          String   @id @default(cuid())
  phone       String
  messageId   String
  otpRefNo    String?
  pendingName String?
  expiresAt   DateTime
  createdAt   DateTime @default(now())
  consumedAt  DateTime?

  @@index([phone, createdAt])
  @@index([messageId])
}

model Order {
  id                 String            @id @default(cuid())
  orderNumber        String            @unique
  /// Per-branch daily queue (1, 2, 3…) reset each operating day
  queueNumber        Int
  /// Operating / queue day for this branch (paired with queueNumber; not migrated for old rows)
  queueBusinessDate  DateTime          @db.Date
  customerId         String
  branchId           String
  fulfillmentType    FulfillmentType   @default(DELIVERY)
  deliveryLocationId String?
  addressDetail      String?
  /// Pin for custom / “อื่น” delivery — distance shown to staff
  deliveryLatitude   Float?
  deliveryLongitude  Float?
  customerName       String            @default("")
  customerPhone      String            @default("")
  /// True when this was the customer's first order at this branch
  isNewCustomer      Boolean           @default(false)
  scheduledAt        DateTime?
  note               String?
  /// Snapshot of applied cart promo, e.g. "โปร 10+1 (−฿15)"
  promoSummary       String?
  paymentMethod      PaymentMethod     @default(CASH)
  /// Staff-selected channel; customer online orders are always ORDER_CUSTOMER
  salesChannel       SalesChannel      @default(STOREFRONT)
  deliveryFee        Decimal           @default(0) @db.Decimal(10, 2)
  discountAmount     Decimal           @default(0) @db.Decimal(10, 2)
  status             OrderStatus       @default(WAITING_FOR_STORE_ACCEPTANCE)
  cancelledAt        DateTime?
  /// Why the order was cancelled (customer or staff)
  cancelReason       String?
  /// Staff who keyed a walk-in order (null for customer online orders)
  createdByStaffId   String?
  /// Staff sales round this order belongs to (null for legacy rows)
  shiftId            String?
  /// Reference photo for rush “key later” orders
  photoUrl           String?
  /// True until staff finishes keying items from the photo (not counted as sales yet)
  awaitingPhotoKey   Boolean           @default(false)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customer           Customer          @relation(fields: [customerId], references: [id])
  branch             Branch            @relation(fields: [branchId], references: [id])
  deliveryLocation   DeliveryLocation? @relation(fields: [deliveryLocationId], references: [id])
  createdByStaff     Staff?            @relation("OrderCreatedByStaff", fields: [createdByStaffId], references: [id], onDelete: SetNull)
  shift              BranchShift?      @relation(fields: [shiftId], references: [id], onDelete: SetNull)
  items              OrderItem[]

  @@unique([branchId, queueBusinessDate, queueNumber])
  @@index([branchId, queueBusinessDate])
  @@index([branchId, awaitingPhotoKey])
  @@index([shiftId])
}

model OrderItem {
  id               String          @id @default(cuid())
  orderId          String
  /// Nullable so admin can delete menu items; order history keeps itemName snapshot.
  branchMenuItemId String?
  itemName         String
  quantity         Int
  unitPrice        Decimal         @db.Decimal(10, 2)
  optionsText      String?
  optionsPrice     Decimal         @default(0) @db.Decimal(10, 2)
  /// Free pieces from promo packs (e.g. 10+1 → 1 per set)
  giftQuantity     Int             @default(0)
  note             String?
  order            Order           @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branchMenuItem   BranchMenuItem? @relation(fields: [branchMenuItemId], references: [id], onDelete: SetNull)
}
