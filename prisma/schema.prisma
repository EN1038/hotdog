generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

enum OrderStatus {
  WAITING_FOR_STORE_ACCEPTANCE
  PREPARING
  READY_FOR_PICKUP
  READY_FOR_DELIVERY
  DELIVERING
  COMPLETED
  CANCELLED
}

enum FulfillmentType {
  PICKUP
  DELIVERY
}

enum PaymentMethod {
  CASH
  TRANSFER
  CARD
}

enum StaffRole {
  SELLER
  DELIVERY
}

enum PriceRange {
  UNDER_100
  FROM_101_250
  FROM_251_500
  FROM_501_1000
  OVER_1000
}

model Admin {
  id           String   @id @default(cuid())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Brand {
  id        String   @id @default(cuid())
  code      String   @unique
  name      String
  nameTh    String?
  nameEn    String?
  logoUrl   String?
  color     String   @default("#dc2626")
  createdAt DateTime @default(now())
  branches  Branch[]
}

model SiteSettings {
  id              String   @id @default("default")
  siteName        String   @default("HunterDog")
  siteTitle       String   @default("HunterDog - ระบบสั่งอาหาร")
  siteDescription String?
  logoUrl         String?
  faviconUrl      String?
  primaryColor    String   @default("#dc2626")
  updatedAt       DateTime @updatedAt
}

model Branch {
  id                 String             @id @default(cuid())
  brandId            String?
  code               String?
  name               String
  nameTh             String?
  nameEn             String?
  imageUrl           String?
  address            String?
  latitude           Float?
  longitude          Float?
  phone              String?
  primaryCategory    String?
  secondaryCategories String[]           @default([])
  priceRange         PriceRange?
  ownerMessage       String?
  extraMessage       String?
  isOpen             Boolean            @default(true)
  /** @deprecated Prefer storefrontHours / deliveryHours */
  opensAt            String?
  /** @deprecated Prefer storefrontHours / deliveryHours */
  closesAt           String?
  storefrontHours    Json?
  deliveryHours      Json?
  allowAdvanceOrder  Boolean            @default(true)
  autoAcceptOrders   Boolean            @default(false)
  createdAt          DateTime           @default(now())
  brand              Brand?               @relation(fields: [brandId], references: [id])
  staff              Staff[]
  menuItems          BranchMenuItem[]
  menuCategories     MenuCategory[]
  optionGroups       BranchOptionGroup[]
  deliveryLocations  DeliveryLocation[]
  orders             Order[]
  shareCodes         BranchShareCode[]

  @@unique([brandId, code])
}

model Staff {
  id        String                @id @default(cuid())
  branchId  String
  phone     String                @unique
  name      String?
  gender    String?
  age       Int?
  imageUrl  String?
  isActive  Boolean               @default(true)
  createdAt DateTime              @default(now())
  branch    Branch                @relation(fields: [branchId], references: [id], onDelete: Cascade)
  roles     StaffRoleAssignment[]
}

model StaffRoleAssignment {
  id      String    @id @default(cuid())
  staffId String
  role    StaffRole
  staff   Staff     @relation(fields: [staffId], references: [id], onDelete: Cascade)

  @@unique([staffId, role])
}

model BranchMenuItem {
  id               String                       @id @default(cuid())
  branchId         String
  name             String
  price            Decimal                      @db.Decimal(10, 2)
  description      String?
  categoryId       String?
  imageUrl         String?
  isHidden         Boolean                      @default(false)
  isOutOfStock     Boolean                      @default(false)
  sortOrder        Int                          @default(0)
  createdAt        DateTime                     @default(now())
  updatedAt        DateTime                     @updatedAt
  branch           Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  category         MenuCategory?                @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  optionGroupLinks BranchMenuItemOptionGroup[]
  orderItems       OrderItem[]
}

model MenuCategory {
  id        String           @id @default(cuid())
  branchId  String
  name      String
  sortOrder Int              @default(0)
  createdAt DateTime         @default(now())
  branch    Branch           @relation(fields: [branchId], references: [id], onDelete: Cascade)
  menuItems BranchMenuItem[]

  @@unique([branchId, name])
}

/** Copy pack code — paste into another branch to import menu/categories/options */
model BranchShareCode {
  id             String   @id @default(cuid())
  code           String   @unique
  sourceBranchId String
  createdAt      DateTime @default(now())
  sourceBranch   Branch   @relation(fields: [sourceBranchId], references: [id], onDelete: Cascade)
}

/** Shared option heading library per branch */
model BranchOptionGroup {
  id           String                       @id @default(cuid())
  branchId     String
  name         String
  required     Boolean                      @default(false)
  maxSelect    Int                          @default(1)
  createdAt    DateTime                     @default(now())
  branch       Branch                       @relation(fields: [branchId], references: [id], onDelete: Cascade)
  options      BranchOption[]
  menuItemLinks BranchMenuItemOptionGroup[]
}

model BranchOption {
  id         String            @id @default(cuid())
  groupId    String
  name       String
  priceDelta Decimal           @default(0) @db.Decimal(10, 2)
  createdAt  DateTime          @default(now())
  group      BranchOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)
}

model BranchMenuItemOptionGroup {
  id         String            @id @default(cuid())
  menuItemId String
  groupId    String
  createdAt  DateTime          @default(now())
  menuItem   BranchMenuItem    @relation(fields: [menuItemId], references: [id], onDelete: Cascade)
  group      BranchOptionGroup @relation(fields: [groupId], references: [id], onDelete: Cascade)

  @@unique([menuItemId, groupId])
}

model DeliveryLocation {
  id       String  @id @default(cuid())
  branchId String
  name     String
  branch   Branch  @relation(fields: [branchId], references: [id], onDelete: Cascade)
  orders   Order[]
}

model Customer {
  id        String   @id @default(cuid())
  phone     String   @unique
  name      String?
  createdAt DateTime @default(now())
  orders    Order[]
}

model Order {
  id                 String            @id @default(cuid())
  orderNumber        String            @unique
  customerId         String
  branchId           String
  fulfillmentType    FulfillmentType   @default(DELIVERY)
  deliveryLocationId String?
  addressDetail      String?
  customerName       String            @default("")
  customerPhone      String            @default("")
  scheduledAt        DateTime?
  note               String?
  paymentMethod      PaymentMethod     @default(CASH)
  deliveryFee        Decimal           @default(0) @db.Decimal(10, 2)
  discountAmount     Decimal           @default(0) @db.Decimal(10, 2)
  status             OrderStatus       @default(WAITING_FOR_STORE_ACCEPTANCE)
  cancelledAt        DateTime?
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt
  customer           Customer          @relation(fields: [customerId], references: [id])
  branch             Branch            @relation(fields: [branchId], references: [id])
  deliveryLocation   DeliveryLocation? @relation(fields: [deliveryLocationId], references: [id])
  items              OrderItem[]
}

model OrderItem {
  id               String         @id @default(cuid())
  orderId          String
  branchMenuItemId String
  itemName         String
  quantity         Int
  unitPrice        Decimal        @db.Decimal(10, 2)
  optionsText      String?
  optionsPrice     Decimal        @default(0) @db.Decimal(10, 2)
  note             String?
  order            Order          @relation(fields: [orderId], references: [id], onDelete: Cascade)
  branchMenuItem   BranchMenuItem @relation(fields: [branchMenuItemId], references: [id])
}
