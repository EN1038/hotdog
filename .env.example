# Copy to .env / .env.local and fill in values

DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DB"
JWT_SECRET="change-me"

# Public URL for customer links/QR (no trailing slash)
NEXT_PUBLIC_APP_URL=https://order.skillsale.co

# DigitalOcean Spaces (S3-compatible) — optional; falls back to public/uploads
S3_ENDPOINT=https://sgp1.digitaloceanspaces.com
S3_REGION=sgp1
S3_BUCKET=skillsale
S3_PUBLIC_URL=https://skillsale.sgp1.digitaloceanspaces.com
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_KEY_PREFIX=SkillSale/Orders

# Taximail SMS OTP (customer login)
TAXIMAIL_API_KEY=
TAXIMAIL_SECRET_KEY=
TAXIMAIL_OTP_TEMPLATE_KEY=SkillSaleOTP
